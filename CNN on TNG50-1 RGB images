def load_tng(path):
    """Load + convert + center + noise‑augment a TNG FITS image."""
    img = fits_to_pil_gzd5(path)
    if img is None:
        return None
    img = center_on_brightest(img)
    arr = np.array(img)
    _, noisy = gaussian_noise(arr, mean=0, stddev=5)
    return Image.fromarray(noisy)


def load_gzd(path):
    """Load a GZD‑5 JPEG/PNG and apply center crop."""
    img = Image.open(path)
    return transforms.CenterCrop(180)(img)


def load_image(row):
    """Dispatch loader based on dataset source."""
    return load_tng(row["path"]) if row["source"] == "tng" else load_gzd(row["path"])


