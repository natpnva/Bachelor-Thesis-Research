# ----------------------------------------------------------------
# FITS → RGB CONVERSION (GZD‑5 STYLE)
# Implements the 2.3 pipeline from Walmsley et al. (2022)

def fits_to_pil_gzd5(fits_path):
    """Convert a 4‑band GZD‑5 FITS file into an RGB PIL image."""
    try:
        with fits.open(fits_path) as hdul:
            data = hdul[0].data  # shape: (4, H, W)

        # g=0, r=1, i=2, z=3  → use g,r,z for RGB
        g = data[0].astype(np.float64)
        r = data[1].astype(np.float64)
        z = data[3].astype(np.float64)

        # Step 1: flux scaling (Lupton convention)
        r_ch = z * 52.63
        g_ch = r * 71.43
        b_ch = g * 125.0
        rgb = np.stack([r_ch, g_ch, b_ch], axis=-1)

        # Step 2: saturation reduction for low‑flux pixels
        T = 90.0
        lam_nm = 600.0
        mean_flux = rgb.mean(axis=-1, keepdims=True)
        N_proxy = np.abs(mean_flux) * T / lam_nm
        alpha = np.minimum(0.01 * np.sqrt(np.maximum(N_proxy, 0)), 1.0)
        rgb = mean_flux + alpha * (rgb - mean_flux)

        # Step 3: arcsinh stretch
        rgb = np.arcsinh(rgb)

        # Step 4: linear stretch to 0–255 using actual data range
        rgb_min = rgb.min()
        rgb_max = np.percentile(rgb, 99.5)
        rgb = (rgb - rgb_min) / (rgb_max - rgb_min) * 255.0
        rgb = np.clip(rgb, 0, 255).astype(np.uint8)

        return Image.fromarray(rgb, mode="RGB")

    except Exception as e:
        print(f"fits_to_pil_gzd5 failed on {fits_path}: {e}")
        return None


# ----------------------------------------------------------------
# IMAGE PREPROCESSING

def center_on_brightest(img_pil, margin=0.3):
    """Crop image around brightest pixel (ignoring edges)."""
    arr = np.array(img_pil.convert("L"))
    H, W = arr.shape

    m = int(min(H, W) * margin)
    interior = arr[m:H-m, m:W-m]

    peak_y, peak_x = np.unravel_index(np.argmax(interior), interior.shape)
    peak_y += m
    peak_x += m

    half = min(peak_y, H - peak_y, peak_x, W - peak_x)
    return img_pil.crop((peak_x - half, peak_y - half, peak_x + half, peak_y + half))


def gaussian_noise(img, mean, stddev, gamma=1):
    """Add Gaussian noise to an image using OpenCV."""
    gauss = np.zeros(img.shape[:2])
    cv2.randn(gauss, mean, stddev)
    gauss = (gauss * gamma).astype(np.uint8)

    if img.ndim == 2:
        return gauss, cv2.add(img, gauss)
    else:
        merged = cv2.merge([gauss, gauss, gauss])
        return gauss, cv2.add(img, merged)


def make_transform():
    """Standard grayscale → resize → tensor transform."""
    return transforms.Compose([
        transforms.Grayscale(num_output_channels=1),
        transforms.Resize((128, 128)),
        transforms.ToTensor(),
    ])


# ----------------------------------------------------------------
# MODEL

class ConvBlock(nn.Module):
    """Conv → BatchNorm → ReLU → MaxPool block."""
    def __init__(self, in_channels, out_channels):
        super().__init__()
        self.block = nn.Sequential(
            nn.Conv2d(in_channels, out_channels, 3, padding=1),
            nn.BatchNorm2d(out_channels),
            nn.ReLU(inplace=True),
            nn.MaxPool2d(2, 2),
        )

    def forward(self, x):
        return self.block(x)


class GalaxyCNN(nn.Module):
    """Simple CNN for predicting 10 Galaxy Zoo vote fractions."""
    def __init__(self, num_targets):
        super().__init__()
        self.features = nn.Sequential(
            ConvBlock(1, 64),
            ConvBlock(64, 128),
            ConvBlock(128, 256),
            ConvBlock(256, 512),
        )
        self.gap = nn.AdaptiveAvgPool2d(1)
        self.head = nn.Sequential(
            nn.Dropout(0.4),
            nn.Linear(512, 128),
            nn.ReLU(inplace=True),
            nn.Linear(128, num_targets),
            nn.Sigmoid(),
        )

    def forward(self, x):
        x = self.features(x)
        x = self.gap(x).flatten(1)
        return self.head(x)


