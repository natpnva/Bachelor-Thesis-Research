# EVALUATION: compare predicted vs ground-truth labels

def evaluate_labels(model, loader):
    model.eval()

    all_preds = []
    all_targets = []

    with torch.no_grad():
        for images, targets in loader:
            images = images.to(DEVICE)
            preds = model(images).cpu().numpy()
            all_preds.append(preds)
            all_targets.append(targets.numpy())

    # Concatenate batches
    all_preds = np.concatenate(all_preds, axis=0)
    all_targets = np.concatenate(all_targets, axis=0)

    # Convert to DataFrames
    pred_df = pd.DataFrame(all_preds, columns=TARGET_COLS)
    target_df = pd.DataFrame(all_targets, columns=TARGET_COLS)

    # Use classifier
    pred_labels = pred_df.apply(classify_galaxy, axis=1)
    target_labels = target_df.apply(classify_galaxy, axis=1)

    # Overall accuracy
    # percentage of validation galaxies where the predicted label matches the true label, 
    # both derived by running fractions through classify_galaxy
    accuracy = (pred_labels == target_labels).mean() 

    # Per-class accuracy, new
    # same but broken down per class (elliptical, spiral, barred spiral, other). Tells you which classes the model struggles with.
    class_accuracy = {}
    for cls in target_labels.unique():
        mask = target_labels == cls
        if mask.sum() > 0:
            class_accuracy[cls] = (pred_labels[mask] == cls).mean()

    # Distribution (useful for debugging), new
    pred_dist = pred_labels.value_counts(normalize=True) # what classes your model actually predicts, if this looks very different from target_dist, the model is biased toward certain classes
    target_dist = target_labels.value_counts(normalize=True) # true class distribution in your validation set

    type_order = ['elliptical', 'spiral', 'barred spiral', 'other']

    cm = confusion_matrix(target_labels, pred_labels, labels=type_order)
    report = classification_report(target_labels, pred_labels, labels=type_order)

    f1 = f1_score(target_labels, pred_labels, labels=type_order, average='weighted') # weighted = each class's score is weighted by how many examples it has 
    precision = precision_score(target_labels, pred_labels, labels=type_order, average='weighted')
    recall = recall_score(target_labels, pred_labels, labels=type_order, average='weighted')

    return {
        "Overall accuracy": accuracy,
        "Accuracy per class": class_accuracy,
        "Predicted distribution": pred_dist,
        "True distribution": target_dist,
        "Predicted labels": pred_labels,
        "True labels": target_labels,
        "Confusion matrix": cm,
        "Classification report": report,
        "F1 score": f1,
        "Precision": precision,
        "Recall": recall,
    }

def plot_confusion_matrix(cm, labels):
    fig, ax = plt.subplots(figsize=(6, 5)) # creates a 6x5 inch figure
    im = ax.imshow(cm, interpolation='nearest', cmap=plt.cm.Blues) # draws the matrix as a heatmap, darker blue = higher number
    plt.colorbar(im, ax=ax) # adds the color scale bar on the right

    ax.set(
        xticks=np.arange(len(labels)), # where to put x ticks marks
        yticks=np.arange(len(labels)), # where to put y ticks marks
        xticklabels=labels, # label each column with class name
        yticklabels=labels, # label each row with class name
        xlabel='Predicted label',
        ylabel='True label',
        title='Confusion Matrix'
    )

    plt.setp(ax.get_xticklabels(), rotation=45, ha='right', rotation_mode='anchor') # rotates x labels 45 degrees so they don't overlap

    # annotate each cell with the count
    thresh = cm.max() / 2.0
    # halfway point between 0 and the highest count in the matrix
    # used to decide whether to write numbers in white or black
    for i in range(len(labels)): # loop over rows (true classes)
        for j in range(len(labels)): # loop over columns (predicted classes)
            ax.text(j, i, format(cm[i, j], 'd'), # write the count as an integer
                    ha='center', va='center', # center the text in the cell
                    color='white' if cm[i, j] > thresh else 'black') # white text on dark blue cells, black text on light cells so the number is always readable

    fig.tight_layout()  # prevents labels from being cut off at the edges
    plt.show()

