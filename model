# TRAINING & VALIDATION LOOPS
# training = look at data, measure error and adjust, validation = look at data and measure error but don't adjust
# reminder ! loader is how many steps per epoch, not how many batches total, the batch size is images per steps
def train_epoch(model, loader, optimizer, criterion): # function that runs one full training epoch
    model.train() # Puts model in training mode, which enables behaviors like dropout and batch normalization that are specific to training
    total_loss = 0.0 # cumulative loss for the epoch, keeps track of sum of losses over the whole epoch
    for i, (images, targets) in enumerate(loader): # Loop over batches, i is batch index, images = batch inputs, targets = batch labels     
        images, targets = images.to(DEVICE), targets.to(DEVICE) # move to cpu
        optimizer.zero_grad() # 0 out gradients from previous step
        preds = model(images) # predictions from the model are the model applied to the images
        loss = criterion(preds, targets) # computes how wrong predictions are
        loss.backward() # backpropagation
        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0) # gradient clipping to prevent exploding gradients, if gradient norm > 1 → scale it down
        optimizer.step() # Updates model weights using gradients
        if torch.isnan(targets).any():
            print("NaN in targets")
        total_loss += loss.item() * len(images) # compute total loss
        if torch.isnan(loss): # trying to debug
            print("NaN loss detected")
            print("Preds min/max:", preds.min().item(), preds.max().item())
            print("Targets min/max:", targets.min().item(), targets.max().item())
    return total_loss / len(loader.dataset)


def val_epoch(model, loader, criterion):
    model.eval()
    total_loss = 0.0

    with torch.no_grad():
        for images, targets in loader:
            images, targets = images.to(DEVICE), targets.to(DEVICE)
            preds = model(images)
            loss = criterion(preds, targets)

            total_loss += loss.item() * len(images)

    return total_loss / len(loader.dataset)

