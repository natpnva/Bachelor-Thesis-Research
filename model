# MAIN

def main():
    # Load parquet
    print(f"\nLoading data from {PARQUET_PATH}...")
    df = pd.read_parquet(PARQUET_PATH)
    n_before = len(df)
    print(f"Before NaN removal: {n_before}")
    df[TARGET_COLS] = df[TARGET_COLS].fillna(0)
    labels = df[TARGET_COLS].apply(classify_galaxy, axis=1) 
    print("\nFull dataset class distribution:")
    print(labels.value_counts(normalize=True))

    train_df, val_df, test_df = split_dataset(df)
    train_ds = GalaxyDataset(train_df, IMAGE_ROOT, IMAGE_COL, TARGET_COLS, train_transform) #dataset for training
    val_ds = GalaxyDataset(val_df, IMAGE_ROOT, IMAGE_COL, TARGET_COLS, val_transform) #dataset for validation, no augmentation
    test_ds = GalaxyDataset(test_df, IMAGE_ROOT, IMAGE_COL, TARGET_COLS, val_transform) #dataset for testing, no augmentation

    train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True,
                              num_workers=NUM_WORKERS, pin_memory=False)
    val_loader   = DataLoader(val_ds, batch_size=BATCH_SIZE, shuffle=False,
                              num_workers=NUM_WORKERS, pin_memory=False)
    
    print(f"Train: {len(train_df)}")
    print(f"Validation: {len(val_df)}")
    print(f"Test: {len(test_df)}")

    # Model, loss, optimizer
    model = GalaxyCNN(NUM_TARGETS).to(DEVICE)
    criterion = nn.MSELoss() # regression loss for fraction targets
    optimizer = torch.optim.Adam(model.parameters(), lr=LR)
    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(
                    optimizer, patience=5, factor=0.3, min_lr=1e-6)

    print(f"Training on {DEVICE} — {len(train_ds)} training / {len(val_ds)} validation")
    print(f"Model parameters: {sum(p.numel() for p in model.parameters()):,}\n")

    best_val_loss = float("inf")

    train_losses = []
    val_losses = []
    val_accuracies = []

    for epoch in range(1, NUM_EPOCHS + 1):
        train_loss = train_epoch(model, train_loader, optimizer, criterion)
        val_loss = val_epoch(model, val_loader, criterion)
        scheduler.step(val_loss)
        #val_accuracy, _, _ = evaluate_labels(model, val_loader)

        train_losses.append(train_loss)
        val_losses.append(val_loss)

        if val_loss < best_val_loss:
            best_val_loss = val_loss
            torch.save(model.state_dict(), "best_galaxy_cnn.pt")

        if epoch % 10 == 0:
            try:
                metrics = evaluate_labels(model, val_loader)
                val_accuracies.append((epoch, metrics["Overall accuracy"]))
                print(f"EPOCH {epoch:>3}/{NUM_EPOCHS}: "
                    f"TRAIN LOSS = {train_loss:.4f}, VAL LOSS = {val_loss:.4f}, "
                    f"ACCURACY = {metrics['Overall accuracy']:.2%}")
            except Exception as e:
                print(f"evaluate_labels failed: {e}")
                import traceback
                traceback.print_exc()

    print("\nLoading best model for final evaluation...")
    model.load_state_dict(torch.load("best_galaxy_cnn.pt"))
    metrics = evaluate_labels(model, val_loader)
    plot_confusion_matrix(metrics["Confusion matrix"], ['elliptical', 'spiral', 'barred spiral', 'other'])

    print(f"\nFinal accuracy: {metrics['Overall accuracy']:.2%}")
    print(f"F1 score: {metrics['F1 score']:.4f}")
    print(f"Precision: {metrics['Precision']:.4f}")
    print(f"Recall: {metrics['Recall']:.4f}")
    print("\nPer-class accuracy:")
    for cls, acc in metrics["Accuracy per class"].items():
        print(f"  {cls}: {acc:.2%}")
    print("\nClassification report:")
    print(metrics["Classification report"])
    print("\nConfusion matrix:")
    print(metrics["Confusion matrix"])
    print("\nTrue distribution:")
    print(metrics["True distribution"])
    print("\nPredicted distribution:")
    print(metrics["Predicted distribution"])

    epochs = range(1, NUM_EPOCHS + 1)

    plt.figure()
    plt.plot(epochs, train_losses, label="Train Loss")
    plt.plot(epochs, val_losses, label="Validation Loss")
    plt.xlabel("Epoch")
    plt.ylabel("Loss")
    plt.title("Training vs Validation Loss")
    plt.legend()
    plt.grid()
    plt.show()

    acc_epochs, acc_values = zip(*val_accuracies)
    plt.figure()
    plt.plot(acc_epochs, acc_values, label="Validation Accuracy", marker='o')
    plt.xlabel("Epoch")
    plt.ylabel("Accuracy")
    plt.title("Validation Accuracy Over Time")
    plt.legend()
    plt.grid()
    plt.show()


if __name__ == "__main__":
    main()
