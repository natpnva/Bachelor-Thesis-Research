# DATASET

class GalaxyDataset(Dataset): #create dataset class
    def __init__(self, df, image_root, image_col, target_cols, transform=None): #initialize dataset
        self.df = df.reset_index(drop=True) #reset index of dataframe
        self.image_root = image_root 
        self.image_col = image_col
        self.target_cols = target_cols
        self.transform = transform

    def __len__(self): #return number of samples in dataset, needed for PyTorch to know how many batches there are per epoch
        return len(self.df)

    def __getitem__(self, idx): #get item at index idx
        row = self.df.iloc[idx] #get row at index idx
        img_path = os.path.join(self.image_root, row[self.image_col]) #construct full image path
        image = Image.open(img_path) #open image, don't convert to RGB bc image is alreayd in that format

        if self.transform:
            image = self.transform(image) #apply transformations to image

        targets = torch.tensor(row[self.target_cols].values.astype(np.float32)) #get target values and convert to tensor
        return image, targets

def split_dataset(df, train_frac=0.8, val_frac=0.1, test_frac=0.1, seed=42):
    assert abs(train_frac + val_frac + test_frac - 1.0) < 1e-6 #fractions must sum to 1

    df = df.sample(frac=1, random_state=seed).reset_index(drop=True) #shuffle dataframe and reset index so it doesn't go linearly

    n = len(df)
    train_end = int(train_frac * n) #end index for train
    val_end = train_end + int(val_frac * n) #end index for val

    train_df = df.iloc[:train_end] #train = start to train_end
    val_df = df.iloc[train_end:val_end] #val = train_end to val_end
    test_df = df.iloc[val_end:] #test = val_end to end

    return train_df, val_df, test_df

