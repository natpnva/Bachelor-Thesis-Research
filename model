# MODEL

class ConvBlock(nn.Module): # conv block = conv → batchnorm → relu → maxpool
    def __init__(self, in_channels, out_channels): #initialize conv block
        super().__init__() # call parent constructor
        self.block = nn.Sequential( # sequential container for layers
            nn.Conv2d(in_channels, out_channels, kernel_size=3, padding=1), # conv layer with 3x3 kernel and padding of 1 to preserve spatial dimensions
            nn.BatchNorm2d(out_channels), # batch normalization to stabilize training and improve convergence
            nn.ReLU(inplace=True), # ReLU activation, inplace just saves memory
            nn.MaxPool2d(2, 2), # max pooling with 2x2 kernel, halves hight and width
        )

    def forward(self, x): # forward pass through conv block, same as call() in Keras
        return self.block(x) #apply sequential layers to input x


class GalaxyCNN(nn.Module): # CNN model for galaxy classification
    def __init__(self, num_targets): #initialize model with number of target outputs
        super().__init__()
        self.features = nn.Sequential( # stack of conv blocks to extract features from input images
            ConvBlock(1, 64), # input 1 output 64 channels
            ConvBlock(64, 128),
            ConvBlock(128, 256),   
            ConvBlock(256, 512), # final output is 512 channels with spatial dimensions 14×14 (after 4 rounds of 2x2 pooling from 64x64 input
        )
        self.gap = nn.AdaptiveAvgPool2d(1) # GAP to reduce spatial dimensions to 1x1, resulting in a 512-dimensional feature vector for each image
        self.head = nn.Sequential( # fully connected layers to map features to target outputs, dense layer in Keras
            nn.Dropout(0.4), # 40% dropout to prevent overfitting
            nn.Linear(512, 128), # fully connected layer from 512 features to 128 hidden units
            nn.ReLU(inplace=True), 
            nn.Linear(128, num_targets), # fully connected layer from 128 hidden units to num_targets outputs
            nn.Sigmoid(), # sigmoid activation to output probabilities between 0 and 1 for each target class
        )

    def forward(self, x): # forward pass through the model
        x = self.features(x) # extract features using conv blocks
        x = self.gap(x) # apply GAP to reduce spatial dimensions to 1x1
        x = x.flatten(1)  # (batch, nb of channels)
        return self.head(x)
   
